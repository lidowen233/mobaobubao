generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider = "sqlite" 
  url      = "file:./mojiji.db"
  
}

model Copybook {
  id            String         @id @default(cuid())
  title         String
  calligrapher  String
  dynasty       String?
  script        String         @default("KAI")
  description   String?
  source        String         @default("SYSTEM")
  uploaderId    String?
  pages         CopybookPage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model CopybookPage {
  id           String    @id @default(cuid())
  copybookId   String
  pageNumber   Int
  imageUrl     String
  width        Int
  height       Int
  processed    Boolean   @default(false)
  copybook     Copybook  @relation(fields: [copybookId], references: [id], onDelete: Cascade)
  glyphs       Glyph[]
  createdAt    DateTime  @default(now())
  @@unique([copybookId, pageNumber])
}

model Glyph {
  id         String   @id @default(cuid())
  character  String
  pageId     String
  imageUrl   String
  bboxX      Float
  bboxY      Float
  bboxW      Float
  bboxH      Float
  confidence Float?
  verified   Boolean  @default(false)
  uploaderId String?
  page       CopybookPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())


  @@index([character])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
}
